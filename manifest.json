{
  "manifest_version": 3,
  "name": "Poe2Obsidian",
  "short_name": "Poe2Obsidian",
  "version": "0.11.0",
  "description": "Export your Poe.com AI conversations to an Obsidian vault as clean Markdown — one chat or your whole history.",
  "homepage_url": "https://github.com/selectdimensions/ravenvault-chrome",
  "permissions": [
    "scripting",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://poe.com/*",
    "https://*.poe.com/*",
    "https://poecdn.net/*",
    "https://*.poecdn.net/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Poe2Obsidian",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
