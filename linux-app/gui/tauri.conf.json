{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RavenVault",
  "version": "0.9.1",
  "identifier": "app.ravenvault.desktop",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "title": "RavenVault Settings",
        "width": 540,
        "height": 540,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "category": "Utility",
    "shortDescription": "Export Poe.com chats to Obsidian",
    "longDescription": "RavenVault is the local companion that receives Poe.com conversations from the browser extension and saves them as Markdown in your Obsidian vault.",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"]
  }
}
